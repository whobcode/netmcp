# Copy to `.dev.vars` for local dev; set in prod with `npx wrangler secret put <NAME>`.

# --- Required: GitHub OAuth (login) ---
GITHUB_CLIENT_ID=<your github client id>
GITHUB_CLIENT_SECRET=<your github client secret>
COOKIE_ENCRYPTION_KEY=<openssl rand -hex 32>

# Bearer token for the /run REST shim (used by iOS Shortcuts / curl)
# Generate one with: openssl rand -hex 32
SHORTCUT_SECRET=

# --- Optional: external API tools (each enables its tool when set) ---
NVD_API_KEY=              # NIST NVD (higher rate limit)
GITHUB_TOKEN=             # github_exploit_search
GITLAB_TOKEN=             # gitlab_code_search
SHODAN_API_KEY=           # shodan_device_search (100 free/mo)
CENSYS_API_ID=            # censys_host_search
CENSYS_API_SECRET=        # censys_host_search
SECURITYTRAILS_API_KEY=   # securitytrails_dns_history (50 free/mo)
